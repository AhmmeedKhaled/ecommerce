{
  "App": {
    "SelfUrl": "https://localhost:44331",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ecommercetask;Username=postgres;Password=admin;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44331",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "ecommerce_Swagger",
    "CertificatePassPhrase": "172fe258-f41d-4f70-b637-d0e3fd7a6493"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "kTymvHBO0jvZGqfO"
  }}